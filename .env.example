# Get a free key at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Service base URLs
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# Playback providers (add more in src/api/providers/)
VITE_SUPEREMBED_BASE_URL=https://multiembed.mov
# Legacy alias still supported for VidLink:
VITE_PLAYBACK_BASE_URL=https://vidlink.pro
VITE_VIDLINK_BASE_URL=https://vidlink.pro
VITE_2EMBED_BASE_URL=https://www.2embed.online

# Default provider id: superembed | vidlink | 2embed
VITE_PLAYBACK_DEFAULT_PROVIDER=superembed
